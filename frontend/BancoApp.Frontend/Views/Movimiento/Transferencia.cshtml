@{ ViewData["Title"] = "Transferencias"; }

<h2>Transferencias entre Cuentas</h2>
<hr />

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-warning"><h5 class="mb-0">Nueva Transferencia</h5></div>
            <div class="card-body">
                <form id="formTransferencia">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Cuenta Origen</label>
                            <select id="cuentaOrigen" class="form-select" required><option value="">-- Seleccionar --</option></select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Cuenta Destino</label>
                            <select id="cuentaDestino" class="form-select" required><option value="">-- Seleccionar --</option></select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Importe</label>
                            <input type="number" id="importeTransferencia" class="form-control" min="0.01" step="0.01" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Glosa / Descripcion</label>
                            <input type="text" id="glosaTransferencia" class="form-control" maxlength="25" required />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-warning">Realizar Transferencia</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">Cuentas Disponibles</h5></div>
            <div class="card-body" id="listaCuentas"><small class="text-muted">Cargando...</small></div>
        </div>
    </div>
</div>

<div id="resultado" class="alert d-none mt-3"></div>

@section Scripts {
<script>
var API_BASE = 'http://localhost:5000';

$(function() {
    cargarCuentas();

    $('#formTransferencia').on('submit', function(e) {
        e.preventDefault();
        var orig = $('#cuentaOrigen').val();
        var dest = $('#cuentaDestino').val();
        if (orig === dest) { mostrarResultado(false, 'No se puede transferir a la misma cuenta.'); return; }

        var data = {
            CuentaOrigen: orig, CuentaDestino: dest,
            Importe: parseFloat($('#importeTransferencia').val()),
            Glosa: $('#glosaTransferencia').val().trim()
        };
        $.ajax({
            url: API_BASE + '/api/movimientos/transferencia',
            type: 'POST', contentType: 'application/json', data: JSON.stringify(data),
            success: function(res) {
                mostrarResultado(res.exito, res.mensaje);
                if (res.exito) { $('#formTransferencia')[0].reset(); cargarCuentas(); }
            },
            error: function(xhr) {
                var msg = xhr.responseJSON ? xhr.responseJSON.mensaje : 'Error al conectar.';
                mostrarResultado(false, msg);
            }
        });
    });
});

function cargarCuentas() {
    $.get(API_BASE + '/api/cuentas', function(cuentas) {
        var opts = '<option value="">-- Seleccionar --</option>';
        var html = '<ul class="list-group list-group-flush">';
        $.each(cuentas, function(i, c) {
            opts += '<option value="' + c.nroCuenta + '">' + c.nroCuenta + ' - ' + c.nombre + ' (' + c.saldo.toFixed(2) + ')</option>';
            html += '<li class="list-group-item d-flex justify-content-between align-items-center">' +
                     '<span><strong>' + c.nroCuenta + '</strong><br><small>' + c.nombre + '</small></span>' +
                     '<span class="badge bg-primary rounded-pill">' + c.saldo.toFixed(2) + '</span></li>';
        });
        html += '</ul>';
        $('#cuentaOrigen, #cuentaDestino').html(opts);
        $('#listaCuentas').html(cuentas.length ? html : '<p class="text-muted">No hay cuentas.</p>');
    });
}

function mostrarResultado(exito, mensaje) {
    $('#resultado').removeClass('d-none alert-success alert-danger')
        .addClass(exito ? 'alert-success' : 'alert-danger').text(mensaje);
}
</script>
}
